<Window x:Class="FishFirm164.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование товара" Height="550" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource MainBackground}"
        Foreground="{StaticResource TextForeground}">
    <Grid Margin="10" Background="{StaticResource MainBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Название:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <TextBox x:Name="txtProductName" Grid.Row="0" Grid.Column="1" Margin="5" 
                 Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Text="Категория:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <ComboBox x:Name="cmbCategory" Grid.Row="1" Grid.Column="1" Margin="5"
                  DisplayMemberPath="CategoryName" SelectedValuePath="CategoryID"
                  SelectedValue="{Binding CategoryID}"/>

        <TextBlock Text="Производитель:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <ComboBox x:Name="cmbManufacturer" Grid.Row="2" Grid.Column="1" Margin="5"
                  DisplayMemberPath="Name" SelectedValuePath="ManufacturerID"
                  SelectedValue="{Binding ManufacturerID}"/>

        <TextBlock Text="Описание:" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Top" Foreground="White"/>
        <TextBox x:Name="txtDescription" Grid.Row="3" Grid.Column="1" Margin="5" Height="80" 
                 TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding Description}"/>

        <TextBlock Text="Кол-во на складе:" Grid.Row="4" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <TextBox x:Name="txtQuantity" Grid.Row="4" Grid.Column="1" Margin="5" Text="{Binding QuantityInStock}"/>

        <TextBlock Text="Ед. измерения:" Grid.Row="5" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <TextBox x:Name="txtUnit" Grid.Row="5" Grid.Column="1" Margin="5" Text="{Binding Unit}"/>

        <TextBlock Text="Закупочная цена:" Grid.Row="6" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <TextBox x:Name="txtCostPrice" Grid.Row="6" Grid.Column="1" Margin="5" Text="{Binding CostPrice}"/>

        <TextBlock Text="Розничная цена:" Grid.Row="7" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <TextBox x:Name="txtRetailPrice" Grid.Row="7" Grid.Column="1" Margin="5" Text="{Binding RetailPrice}"/>

        <TextBlock Text="Мин. остаток:" Grid.Row="8" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <TextBox x:Name="txtMinStock" Grid.Row="8" Grid.Column="1" Margin="5" Text="{Binding MinStock}"/>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5,20,5,5">
            <Button x:Name="btnSave" Content="Сохранить" Width="80" Margin="0,0,10,0" Click="SaveButton_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="80" Click="BtnCancel_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
        </StackPanel>
    </Grid>
</Window>