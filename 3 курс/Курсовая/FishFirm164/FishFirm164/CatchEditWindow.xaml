<Window x:Class="FishFirm164.CatchEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование улова" Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#2d2d2d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Выход:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <ComboBox x:Name="cmbTrip" Grid.Row="0" Grid.Column="1" Margin="5" DisplayMemberPath="TripDisplay" SelectedValuePath="TripID"/>

        <TextBlock Text="Банка:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <ComboBox x:Name="cmbSpot" Grid.Row="1" Grid.Column="1" Margin="5" DisplayMemberPath="SpotName" SelectedValuePath="SpotID"/>

        <TextBlock Text="Сорт рыбы:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <TextBox x:Name="txtFishType" Grid.Row="2" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Вес (кг):" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <TextBox x:Name="txtWeight" Grid.Row="3" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Качество:" Grid.Row="4" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <ComboBox x:Name="cmbQuality" Grid.Row="4" Grid.Column="1" Margin="5">
            <ComboBoxItem Content="отличное"/>
            <ComboBoxItem Content="хорошее"/>
            <ComboBoxItem Content="плохое"/>
        </ComboBox>

        <TextBlock Text="Дата прихода:" Grid.Row="5" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <DatePicker x:Name="dpArrivalDate" Grid.Row="5" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Дата отплытия:" Grid.Row="6" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <DatePicker x:Name="dpDepartureDate" Grid.Row="6" Grid.Column="1" Margin="5"/>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5,20,5,5">
            <Button Content="Сохранить" Width="80" Margin="0,0,10,0" Click="BtnSave_Click"/>
            <Button Content="Отмена" Width="80" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>