<Window x:Class="FishFirm164.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FishFirm164"
        mc:Ignorable="d"
        Title="Редактирование пользователя" Height="350" Width="450"
        WindowStartupLocation="CenterOwner">
    <Grid  Background="{DynamicResource MainBackground}">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="ФИО:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
            <TextBox x:Name="txtFullName" Grid.Row="0" Grid.Column="1" Margin="5" Text="{Binding FullName}"/>

            <TextBlock Text="Логин:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
            <TextBox x:Name="txtLogin" Grid.Row="1" Grid.Column="1" Margin="5" Text="{Binding Login}"/>

            <TextBlock Text="Пароль:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
            <PasswordBox x:Name="txtPassword" Grid.Row="2" Grid.Column="1" Margin="5"/>

            <TextBlock Text="Роль:" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
            <ComboBox x:Name="cmbRole" Grid.Row="3" Grid.Column="1" Margin="5" DisplayMemberPath="RoleName" SelectedValuePath="RoleID"/>

            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5,15,5,5">
                <Button x:Name="btnSave" Content="Сохранить" Width="80" Margin="0,0,10,0" Click="BtnSave_Click"/>
                <Button x:Name="btnCancel" Content="Отмена" Width="80" Click="BtnCancel_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
