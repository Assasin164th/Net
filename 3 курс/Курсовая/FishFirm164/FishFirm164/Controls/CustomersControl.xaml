<UserControl x:Class="FishFirm164.CustomersControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FishFirm164"
        mc:Ignorable="d"
        Background="#2d2d2d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnAdd" Content="Добавить" Width="100" Margin="0,0,10,0" Click="BtnAdd_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
            <Button x:Name="btnEdit" Content="Изменить" Width="100" Margin="0,0,10,0" Click="BtnEdit_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="100" Click="BtnDelete_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
        </StackPanel>
        <DataGrid x:Name="dgCustomers" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#3d3d3d" Foreground="White" BorderBrush="#555">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding CustomerID}" Width="50"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="150"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="150"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                <DataGridCheckBoxColumn Header="Дисконт" Binding="{Binding DiscountCard}" Width="80"/>
                <DataGridTextColumn Header="Дата регистрации" Binding="{Binding RegistrationDate, StringFormat='dd.MM.yyyy'}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
            <Button Content="&lt;" Width="30" Click="PrevPage_Click" 
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
            <TextBlock x:Name="txtPage" Text="1" VerticalAlignment="Center" Margin="5,0" Foreground="White"/>
            <Button Content="&gt;" Width="30" Click="NextPage_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
        </StackPanel>
    </Grid>
</UserControl>
