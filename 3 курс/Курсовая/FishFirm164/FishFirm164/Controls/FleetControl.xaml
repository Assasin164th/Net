<UserControl x:Class="FishFirm164.Controls.FleetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FishFirm164.Controls"
             Background="{DynamicResource MainBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Left">
            <Button x:Name="btnBoats" Content="Катера" Click="BtnBoats_Click" Margin="5" Width="100"/>
            <Button x:Name="btnCrew" Content="Команда" Click="BtnCrew_Click" Margin="5" Width="100"/>
            <Button x:Name="btnSpots" Content="Банки" Click="BtnSpots_Click" Margin="5" Width="100"/>
            <Button x:Name="btnTrips" Content="Выходы" Click="BtnTrips_Click" Margin="5" Width="100"/>
            <Button x:Name="btnCatch" Content="Улов" Click="BtnCatch_Click" Margin="5" Width="100"/>
        </StackPanel>

        <TabControl x:Name="fleetTabControl" Grid.Row="1" Margin="5"/>
    </Grid>
</UserControl>