<UserControl x:Class="FishFirm164.SalesControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FishFirm164"
        mc:Ignorable="d"
        Background="#2d2d2d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Кнопки управления -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnAdd" Content="Новая продажа" Width="120" Margin="0,0,10,0" Click="BtnAdd_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
            <Button x:Name="btnEdit" Content="Изменить" Width="100" Margin="0,0,10,0" Click="BtnEdit_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="100" Click="BtnDelete_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
        </StackPanel>

        <!-- Таблица продаж -->
        <DataGrid x:Name="dgSales" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionChanged="DgSales_SelectionChanged"
                  Background="#3d3d3d" Foreground="White" BorderBrush="#555" 
                  RowBackground="#3d3d3d" AlternatingRowBackground="#2d2d2d">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID продажи" Binding="{Binding SaleID}" Width="80"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding SaleDate, StringFormat='dd.MM.yyyy HH:mm'}" Width="150"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding Customers.LastName}" Width="150"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat={}{0:C2}}" Width="120"/>
                <DataGridTextColumn Header="Метод оплаты" Binding="{Binding PaymentMethod}" Width="120"/>
                <DataGridTextColumn Header="Продавец" Binding="{Binding Users.FullName}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Пагинация -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="&lt;" Width="30" Click="PrevPage_Click" 
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
            <TextBlock x:Name="txtPage" Text="1" VerticalAlignment="Center" Margin="5,0" Foreground="White"/>
            <Button Content="&gt;" Width="30" Click="NextPage_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
        </StackPanel>
    </Grid>
</UserControl>
