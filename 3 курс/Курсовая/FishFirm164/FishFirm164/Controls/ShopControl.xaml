<UserControl x:Class="FishFirm164.Controls.ShopControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FishFirm164.Controls"
             Background="{DynamicResource MainBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Left">
            <Button x:Name="btnProducts" Content="Товары" Click="BtnProducts_Click" Margin="5" Width="100"/>
            <Button x:Name="btnSales" Content="Продажи" Click="BtnSales_Click" Margin="5" Width="100"/>
            <Button x:Name="btnPurchases" Content="Закупки" Click="BtnPurchases_Click" Margin="5" Width="100"/>
            <Button x:Name="btnCustomers" Content="Клиенты" Click="BtnCustomers_Click" Margin="5" Width="100"/>
            <Button x:Name="btnSuppliers" Content="Поставщики" Click="BtnSuppliers_Click" Margin="5" Width="100"/>
            <Button x:Name="btnUsers" Content="Пользователи" Click="BtnUsers_Click" Margin="5" Width="100"/>
            <Button x:Name="btnReports" Content="Отчёты" Click="BtnReports_Click" Margin="5" Width="100"/>
        </StackPanel>

        <TabControl x:Name="shopTabControl" Grid.Row="1" Margin="5"/>
    </Grid>
</UserControl>