<UserControl x:Class="FishFirm164.Controls.CatchControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource MainBackground}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel Margin="0,0,0,10">
            <TextBlock Text="Поиск по катеру:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="txtSearch" Width="150" TextChanged="TxtSearch_TextChanged"/>
        </WrapPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnAdd" Content="Добавить улов" Width="120" Margin="0,0,10,0" Click="BtnAdd_Click"/>
            <Button x:Name="btnEdit" Content="Изменить" Width="100" Margin="0,0,10,0" Click="BtnEdit_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="100" Click="BtnDelete_Click"/>
        </StackPanel>

        <DataGrid x:Name="dgCatch" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding CatchID}" Width="50"/>
                <DataGridTextColumn Header="Катер" Binding="{Binding Trips.Boats.BoatName}" Width="150"/>
                <DataGridTextColumn Header="Банка" Binding="{Binding FishingSpots.SpotName}" Width="150"/>
                <DataGridTextColumn Header="Сорт рыбы" Binding="{Binding FishType}" Width="100"/>
                <DataGridTextColumn Header="Вес (кг)" Binding="{Binding Weight, StringFormat={}{0:N0}}" Width="80"/>
                <DataGridTextColumn Header="Качество" Binding="{Binding Quality}" Width="80"/>
                <DataGridTextColumn Header="Приход" Binding="{Binding ArrivalDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                <DataGridTextColumn Header="Отплытие" Binding="{Binding DepartureDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="&lt;" Width="30" Click="PrevPage_Click" Margin="0,0,5,0"/>
            <TextBlock x:Name="txtPage" Text="1" VerticalAlignment="Center" Margin="5,0"/>
            <Button Content="&gt;" Width="30" Click="NextPage_Click" Margin="5,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>