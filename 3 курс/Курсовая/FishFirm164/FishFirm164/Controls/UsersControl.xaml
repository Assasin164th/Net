<UserControl x:Class="FishFirm164.UsersControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FishFirm164"
        mc:Ignorable="d"
        Background="#2d2d2d">
    <Grid  Background="{DynamicResource MainBackground}">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <WrapPanel Margin="0,0,0,10">
                <Button x:Name="btnAdd" Content="Добавить" Width="100" Margin="0,0,10,0" Click="BtnAdd_Click"/>
                <Button x:Name="btnEdit" Content="Изменить" Width="100" Margin="0,0,10,0" Click="BtnEdit_Click"/>
                <Button x:Name="btnDelete" Content="Удалить" Width="100" Click="BtnDelete_Click"/>
            </WrapPanel>

            <DataGrid x:Name="dgUsers" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding UserID}" Width="50"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="250"/>
                    <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="200"/>
                    <DataGridTextColumn Header="Роль" Binding="{Binding Roles.RoleName}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
