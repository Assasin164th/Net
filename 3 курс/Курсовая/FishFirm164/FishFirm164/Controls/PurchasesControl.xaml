<UserControl x:Class="FishFirm164.PurchasesControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FishFirm164"
        mc:Ignorable="d"
        Background="#2d2d2d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel Margin="0,0,0,10">
            <Button x:Name="btnAdd" Content="Новая закупка" Width="120" Margin="0,0,10,0" Click="BtnAdd_Click"/>
            <Button x:Name="btnEdit" Content="Редактировать" Width="120" Margin="0,0,10,0" Click="BtnEdit_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="100" Click="BtnDelete_Click"/>
        </WrapPanel>

        <DataGrid x:Name="dgPurchases" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding PurchaseID}" Width="50"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding PurchaseDate, StringFormat={}{0:dd.MM.yyyy}}" Width="150"/>
                <DataGridTextColumn Header="Поставщик" Binding="{Binding Suppliers.CompanyName}" Width="300"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat={}{0:C2}}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
