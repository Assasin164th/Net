<Window x:Class="FishFirm164.SelectProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор товаров" Height="600" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="txtSearch" Margin="0,0,0,10" TextChanged="TxtSearch_TextChanged" 
                 Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>

        <DataGrid x:Name="dgProducts" Grid.Row="1" AutoGenerateColumns="False" 
                  SelectionMode="Extended" HeadersVisibility="Column"
                  Background="#3d3d3d" Foreground="White" BorderBrush="#555">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding RetailPrice, StringFormat={}{0:C2}}" Width="100"/>
                <DataGridTemplateColumn Header="Количество" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding SelectedQuantity, UpdateSourceTrigger=PropertyChanged}" 
                                     Width="60" Background="#3d3d3d" Foreground="White" BorderBrush="#555"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="80" Margin="0,0,10,0" Click="BtnOk_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
            <Button Content="Отмена" Width="80" Click="BtnCancel_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
        </StackPanel>
    </Grid>
</Window>