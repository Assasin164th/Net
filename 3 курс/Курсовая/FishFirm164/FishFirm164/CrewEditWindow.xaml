<Window x:Class="FishFirm164.CrewEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование члена команды" Height="350" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="#2d2d2d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Фамилия:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <TextBox x:Name="txtLastName" Grid.Row="0" Grid.Column="1" Margin="5" Text="{Binding LastName}"/>

        <TextBlock Text="Имя:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <TextBox x:Name="txtFirstName" Grid.Row="1" Grid.Column="1" Margin="5" Text="{Binding FirstName}"/>

        <TextBlock Text="Должность:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center" Foreground="White"/>
        <TextBox x:Name="txtPosition" Grid.Row="2" Grid.Column="1" Margin="5" Text="{Binding Position}"/>

        <TextBlock Text="Адрес:" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Top" Foreground="White"/>
        <TextBox x:Name="txtAddress" Grid.Row="3" Grid.Column="1" Margin="5" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding Address}"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5,20,5,5">
            <Button Content="Сохранить" Width="80" Margin="0,0,10,0" Click="BtnSave_Click"/>
            <Button Content="Отмена" Width="80" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>