<Window x:Class="FishFirm164.SaleEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оформление продажи" Height="650" Width="850"
        WindowStartupLocation="CenterOwner"
        Background="#2d2d2d">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#3d3d3d" CornerRadius="8" Padding="10" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Клиент:" VerticalAlignment="Center" Foreground="White" FontSize="14" Margin="0,0,10,0"/>
                <ComboBox x:Name="cmbCustomer" Width="250" 
                          SelectedValuePath="CustomerID"
                          Background="#3d3d3d" Foreground="White" BorderBrush="#555">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding LastName}" Foreground="White"/>
                                <TextBlock Text=" " Foreground="White"/>
                                <TextBlock Text="{Binding FirstName}" Foreground="White"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="Выбрать товары" Width="140" Margin="20,0,0,0" 
                        Click="BtnSelectProducts_Click"
                        Background="#6a9fb5" Foreground="White" BorderBrush="#555" BorderThickness="1"
                        FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="dgItems" Grid.Row="1" AutoGenerateColumns="False" 
                  Background="#3d3d3d" Foreground="White" BorderBrush="#555"
                  RowBackground="#3d3d3d" AlternatingRowBackground="#2d2d2d"
                  HeadersVisibility="Column" Margin="0,0,0,15">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*" />
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="100"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:C2}}" Width="120"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Total, StringFormat={}{0:C2}}" Width="120"/>
                <DataGridTemplateColumn Header="Удалить" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✖" Click="RemoveItem_Click" Tag="{Binding}" 
                                    Background="#8b3a3a" Foreground="White" BorderBrush="#555" 
                                    Width="30" Height="30" FontSize="14" FontWeight="Bold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="#1e1e1e" CornerRadius="8" Padding="10" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Итого:" Foreground="White" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="txtTotal" Text="0.00" Foreground="#f0b27a" FontSize="24" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Width="120" Height="40" Margin="0,0,15,0" 
                    Click="BtnSave_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"
                    FontWeight="Bold"/>
            <Button Content="Отмена" Width="120" Height="40" 
                    Click="BtnCancel_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
        </StackPanel>
    </Grid>
</Window>