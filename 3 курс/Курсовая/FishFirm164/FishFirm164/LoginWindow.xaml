<Window x:Class="FishFirm164.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="540" Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#2d2d2d">
    <Grid Margin="15" Background="#2d2d2d">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Image Source="/Resources/logo.png" Width="200" Height="200" 
               HorizontalAlignment="Center" Margin="0,0,0,10" Grid.Row="0"/>

        <TextBlock Text="Вход в систему" FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15" 
                   Foreground="White" Grid.Row="1"/>

        <StackPanel Grid.Row="2" Margin="0,5">
            <TextBlock Text="Логин:" FontWeight="SemiBold" Foreground="White"/>
            <TextBox x:Name="txtLogin" Margin="0,5,0,10" Height="30"
                     Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,5">
            <TextBlock Text="Пароль:" FontWeight="SemiBold" Foreground="White"/>
            <TextBox x:Name="txtPassword" Margin="0,5,0,10" Height="30"
                     Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15">
            <Button x:Name="btnLogin" Content="Войти" Width="100" Height="35" Margin="0,0,15,0"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"
                    Click="BtnLogin_Click"/>
            <Button x:Name="btnGuest" Content="Гость" Width="100" Height="35"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"
                    Click="BtnGuest_Click"/>
        </StackPanel>

        <TextBlock x:Name="txtError" Grid.Row="5" Text="" Foreground="Red" Margin="0,10"/>
    </Grid>
</Window>