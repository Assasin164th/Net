<Window x:Class="Library.BookEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Library"
        mc:Ignorable="d"
        Title="Редактирование книги" Height="350" Width="600"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Название:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="txtName" Grid.Row="0" Grid.Column="1" Margin="5" 
                 Text="{Binding CurrentBook.Name}"/>

        <TextBlock Text="Автор:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="txtAuthor" Grid.Row="1" Grid.Column="1" Margin="5" 
                 Text="{Binding CurrentBook.Author}"/>

        <TextBlock Text="Жанр:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbGenre" Grid.Row="2" Grid.Column="1" Margin="5"
                  DisplayMemberPath="Name" SelectedValuePath="Genre"
                  SelectedValue="{Binding CurrentBook.Genre}"/>

        <TextBlock Text="Публикатор:" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbPublisher" Grid.Row="3" Grid.Column="1" Margin="5"
                  DisplayMemberPath="Name" SelectedValuePath="PublisherId"
                  SelectedValue="{Binding CurrentBook.PublisherId}"/>

        <TextBlock Text="Цена:" Grid.Row="4" Grid.Column="0" Margin="5" VerticalAlignment="Top"/>
        <TextBox x:Name="txtPrice" Grid.Row="4" Grid.Column="1" Margin="5" 
                 TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding CurrentBook.Price}"/>

        <TextBlock Text="Активна:" Grid.Row="5" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <CheckBox x:Name="chkIsAvailable" Grid.Row="5" Grid.Column="1" Margin="5"/>

        <TextBlock Text="На складе:" Grid.Row="6" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="txtStockCount" Grid.Row="6" Grid.Column="1" Margin="5" Text="{Binding CurrentBook.StockCount}"/>

        <StackPanel Grid.Row="10" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5,5,5,5">
            <Button x:Name="btnSave" Content="Сохранить" Width="80" Margin="20,0,10,0" Click="SaveButton_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="80" Click="BtnCancel_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1" Margin="20,0,0,0"/>
            <Button x:Name="btnGenre" Content="Добавить жанр" Width="100" Click="BtnCancel_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1" Margin="20,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
