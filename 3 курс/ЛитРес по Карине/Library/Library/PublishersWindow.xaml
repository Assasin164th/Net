<Window x:Class="Library.PublishersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Издательства" Height="500" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель инструментов -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnAdd" Content="Добавить" Width="80" Margin="0,0,10,0" Click="BtnAdd_Click"/>
            <Button x:Name="btnEdit" Content="Редактировать" Width="100" Margin="0,0,10,0" Click="BtnEdit_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="80" Click="BtnDelete_Click"/>
        </StackPanel>

        <DataGrid x:Name="dgPublishers" Grid.Row="1" AutoGenerateColumns="False" 
                  IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                  Margin="0,0,0,10" RowHeaderWidth="0" SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="2*"/>
                <DataGridTextColumn Header="Рейтинг" Binding="{Binding Rating}" Width="*"/>
                <DataGridTextColumn Header="Город" Binding="{Binding CityName}" Width="*"/>
                <DataGridTextColumn Header="Количество книг" Binding="{Binding BookCount}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
            <Button x:Name="btnFirst" Content="Первая" Width="60" Margin="2" Click="BtnFirst_Click"/>
            <Button x:Name="btnPrev" Content="Пред." Width="60" Margin="2" Click="BtnPrev_Click"/>
            <TextBlock Text="Страница" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <TextBox x:Name="txtPageNumber" Width="40" TextAlignment="Center" 
                     TextChanged="TxtPageNumber_TextChanged"/>
            <TextBlock x:Name="txtTotalPages" VerticalAlignment="Center" Margin="5,0,10,0"/>
            <Button x:Name="btnNext" Content="След." Width="60" Margin="2" Click="BtnNext_Click"/>
            <Button x:Name="btnLast" Content="Последняя" Width="70" Margin="2" Click="BtnLast_Click"/>
        </StackPanel>
    </Grid>
</Window>