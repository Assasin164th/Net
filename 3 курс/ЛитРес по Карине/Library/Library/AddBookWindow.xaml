<Window x:Class="Library.AddBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление книги" Height="450" Width="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Название:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="txtName" Grid.Row="0" Grid.Column="1" Margin="5" TextChanged="Txt_TextChanged"/>

        <TextBlock Text="Автор:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="txtAuthor" Grid.Row="1" Grid.Column="1" Margin="5" TextChanged="Txt_TextChanged"/>

        <TextBlock Text="Цена:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="txtPrice" Grid.Row="2" Grid.Column="1" Margin="5" TextChanged="Txt_TextChanged"/>

        <TextBlock Text="Остаток на складе:" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="txtStockCount" Grid.Row="3" Grid.Column="1" Margin="5" TextChanged="Txt_TextChanged"/>

        <TextBlock Text="Издательство:" Grid.Row="4" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbPublisher" Grid.Row="4" Grid.Column="1" Margin="5"
                  DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="Cmb_SelectionChanged"/>

        <TextBlock Text="Жанр:" Grid.Row="5" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbGenre" Grid.Row="5" Grid.Column="1" Margin="5"
                  DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="Cmb_SelectionChanged"/>

        <TextBlock Text="Статус:" Grid.Row="6" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <CheckBox x:Name="chkIsAvailable" Grid.Row="6" Grid.Column="1" Margin="5" 
                  Content="В продаже" VerticalAlignment="Center"/>

        <TextBlock Text="Обложка:" Grid.Row="7" Grid.Column="0" Margin="5" VerticalAlignment="Top"/>
        <StackPanel Grid.Row="7" Grid.Column="1" Margin="5" Orientation="Vertical">
            <Button x:Name="btnSelectCover" Content="Выбрать изображение" Width="140" 
                    Click="BtnSelectCover_Click" Margin="0,0,0,5"/>
            <Image x:Name="imgCover" Width="120" Height="150" Stretch="UniformToFill" 
                   Margin="0,5,0,0" HorizontalAlignment="Left"/>
        </StackPanel>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button x:Name="btnSave" Content="Сохранить" Width="80" Margin="0,0,10,0" Click="BtnSave_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="80" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>