<Window x:Class="Library.EditPublisherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование издательства" Height="350" Width="400"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Название:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="txtName" Grid.Row="0" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Рейтинг (0-5):" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="txtRating" Grid.Row="1" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Город:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbCity" Grid.Row="2" Grid.Column="1" Margin="5"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <TextBlock Text="Описание:" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Top"/>
        <TextBox x:Name="txtDescription" Grid.Row="3" Grid.Column="1" Margin="5" Height="80" 
                 TextWrapping="Wrap" AcceptsReturn="True"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button x:Name="btnSave" Content="Сохранить" Width="80" Margin="0,0,10,0" Click="BtnSave_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="80" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>