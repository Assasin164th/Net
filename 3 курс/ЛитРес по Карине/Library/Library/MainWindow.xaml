<Window x:Class="Library.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Library"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel Margin="0,0,0,10">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="txtSearch" Width="150" TextChanged="TxtSearch_TextChanged"
                 BorderThickness="1"/>

            <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="15,0,5,0"/>
            <ComboBox x:Name="cmbCategory" Width="120" DisplayMemberPath="Name" SelectedValuePath="Id"
                  SelectionChanged="CmbFilter_SelectionChanged"/>

            <TextBlock Text="Производитель:" VerticalAlignment="Center" Margin="15,0,5,0"/>
            <ComboBox x:Name="cmbManufacturer" Width="120" DisplayMemberPath="Name" SelectedValuePath="Id"
                  SelectionChanged="CmbFilter_SelectionChanged"/>

            <Button Content="Сбросить" Width="80" Margin="15,0" Click="BtnResetFilter_Click"
                Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
        </WrapPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnAdd" Content="Добавить товар" Width="120" Margin="0,0,10,0" Click="BtnAdd_Click"
                BorderThickness="1"/>
            <Button x:Name="btnEdit" Content="Изменить" Width="100" Margin="0,0,10,0" Click="BtnEdit_Click"
                BorderThickness="1"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="100" Click="BtnDelete_Click"
                BorderThickness="1"/>
            <TextBlock x:Name="userName" Width="300" HorizontalAlignment="Right"/>
        </StackPanel>

        <ListBox x:Name="lvProducts" Grid.Row="2" 
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             MouseDoubleClick="LvProducts_MouseDoubleClick">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Width="320" Margin="10" Padding="10"
                        Background="#3d3d3d" CornerRadius="8" BorderBrush="#555" BorderThickness="1">
                        <StackPanel>
                            <Border Height="120" Background="#2d2d2d" CornerRadius="5" Margin="0,0,0,10">
                                <Image Source="FallbackValue={StaticResource PlaceholderImage}}"/>
                            </Border>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" Foreground="White" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Genre.Name}" Foreground="#aaa" Margin="0,5,0,0"/>
                            <TextBlock Text="{Binding Publisher.Name}" Foreground="#aaa"/>
                            <TextBlock Text="{Binding StockCount, StringFormat='В наличии: {0} шт.'}" Margin="0,10,0,0" Foreground="#6a9fb5"/>
                            <TextBlock Text="{Binding Price, StringFormat='Цена: {0:C2}'}" FontWeight="Bold" FontSize="18" Foreground="#f0b27a" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="&lt;" Width="30" Click="PrevPage_Click" Margin="0,0,5,0"
                BorderThickness="1"/>
            <TextBlock x:Name="txtPage" Text="1" VerticalAlignment="Center" Margin="5,0" Foreground="White"/>
            <Button Content="&gt;" Width="30" Click="NextPage_Click" Margin="5,0,0,0"
                BorderThickness="1"/>
        </StackPanel>
    </Grid>
</Window>
