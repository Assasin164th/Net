<Window x:Class="Library.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Книжный магазин" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F0F0F0" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="Общая стоимость книг на складе:" FontWeight="Bold" TextAlignment="Right" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="2" x:Name="txtTotalCost" Text="0 руб." FontWeight="Bold" Foreground="DarkGreen" FontSize="14"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Поиск (название/автор):" Margin="5,0,5,5"/>
                    <TextBox x:Name="txtSearch" Grid.Row="1" Grid.Column="0" Margin="5" TextChanged="TxtSearch_TextChanged"/>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Жанр:" Margin="5,0,5,5"/>
                    <ComboBox x:Name="cmbGenre" Grid.Row="1" Grid.Column="1" Margin="5"
                              DisplayMemberPath="Name" SelectedValuePath="Id"
                              SelectionChanged="CmbGenre_SelectionChanged"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Наличие:" Margin="5,0,5,5"/>
                    <CheckBox x:Name="chkOnlyInStock" Grid.Row="1" Grid.Column="2" Margin="5" 
                              Content="Только в наличии" VerticalAlignment="Center"
                              Checked="Filter_Changed" Unchecked="Filter_Changed"/>

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Сортировка:" Margin="5,0,5,5"/>
                    <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" Margin="5">
                        <RadioButton x:Name="rbPriceAsc" Content="Цена ↑" GroupName="Sort" 
                                     Margin="0,0,10,0" Checked="Sort_Changed"/>
                        <RadioButton x:Name="rbPriceDesc" Content="Цена ↓" GroupName="Sort" 
                                     Checked="Sort_Changed"/>
                    </StackPanel>

                    <Button Grid.Row="1" Grid.Column="4" Content="Издательства" Width="100" Margin="5"
                            Click="BtnPublishers_Click"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button x:Name="btnAdd" Content="Добавить" Width="80" Margin="0,0,10,0" Click="BtnAdd_Click"/>
                    <Button x:Name="btnEdit" Content="Редактировать" Width="100" Margin="0,0,10,0" Click="BtnEdit_Click"/>
                    <Button x:Name="btnDelete" Content="Удалить" Width="80" Margin="0,0,10,0" Click="BtnDelete_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="icBooks">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8"
                                Margin="10" Padding="8" Width="200" Height="320"
                                MouseLeftButtonDown="BookBorder_MouseLeftButtonDown"
                                Tag="{Binding}">
                            <StackPanel>
                                <Image x:Name="imgCover" Width="150" Height="200" Stretch="UniformToFill" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,5"/>
                                <TextBlock FontSize="12" Foreground="DarkBlue">
                                    <Run Text="{Binding Price, StringFormat={}{0:F2}}"/> <Run Text="руб."/>
                                </TextBlock>
                                <TextBlock FontSize="11" Margin="0,2,0,2">
                                    <Run Text="На складе: "/><Run Text="{Binding StockCount}"/> <Run Text="шт."/>
                                </TextBlock>
                                <TextBlock x:Name="txtStatus" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsAvailable}" Value="True">
                                <Setter TargetName="txtStatus" Property="Text" Value="В продаже"/>
                                <Setter TargetName="txtStatus" Property="Foreground" Value="Green"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                <Setter TargetName="txtStatus" Property="Text" Value="Снято с продажи"/>
                                <Setter TargetName="txtStatus" Property="Foreground" Value="Red"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>